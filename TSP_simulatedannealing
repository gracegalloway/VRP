import numpy as np
import random
import time
import matplotlib.pyplot as plt
from Functions.functions import *

# np.random.seed(1)  # Uncomment for reproducible testing

# Global parameters
n = 800

# Generate incidence matrix

symmetric = False

incid = np.full((n, n), -np.inf)

lower = np.tril_indices(n, -1)
incid[lower] = np.random.exponential(scale=1.0, size=len(lower[0]))

if symmetric:
    incid = incid + incid.T
else:
    upper = np.triu_indices(n, 1)
    incid[upper] = np.random.exponential(scale=1.0, size=len(upper[0]))

# Route cost
def tsp_route_cost(route, dist):
   return np.sum(dist[route[:-1], route[1:]]) + dist[route[-1], route[0]]

# Check validity
def route_test(route, dist):
    n = dist.shape[0]
    return np.array_equal(np.sort(route), np.arange(n))

# Simulated Annealing TSP
def solve_tsp(incidence, TIME):

    n = incidence.shape[0]

    route = np.random.permutation(n)
    current_cost = tsp_route_cost(route, incidence)

    best_route = route.copy()
    best_cost = current_cost

    temperature = 1000
    
    history = []
    iterations = 0

    start_time = time.time()

    while time.time() - start_time < TIME:

        for _ in range(1000):

            move = random.choices(
                ["relocate", "swap", "2-opt"],
                weights=[0.33, 0.33, 0.34]
            )[0]

            if move == "relocate":

                idx1 = random.randrange(n)
                node = route[idx1]

                newroute = np.delete(route, idx1)

                idx2 = random.randrange(n)

                newroute = np.insert(newroute, idx2, node)

                iterations += 1

            elif move == "swap":

                idx1, idx2 = random.sample(range(n), 2)

                newroute = route.copy()

                newroute[idx1], newroute[idx2] = (
                    newroute[idx2],
                    newroute[idx1],
                )

            else:      # 2-opt

                idx1, idx2 = sorted(random.sample(range(n), 2))

                newroute = route.copy()

                newroute[idx1:idx2 + 1] = newroute[idx1:idx2 + 1][::-1]

            new_cost = tsp_route_cost(newroute, incidence)

            cost_diff = new_cost - current_cost

            alpha = random.random()

            if cost_diff <= 0:

                route = newroute
                current_cost = new_cost

                if new_cost < best_cost:
                    best_cost = new_cost
                    best_route = newroute.copy()

            elif np.exp(-cost_diff / temperature) > alpha:

                route = newroute
                current_cost = new_cost

                if new_cost < best_cost:
                    best_cost = new_cost
                    best_route = newroute.copy()

            temperature *= 0.999

            if iterations % 100 == 0:
                history.append(best_cost)

    return {
        "route": best_route,
        "history": history,
        "best_cost": best_cost,
        "iterations": iterations,
    }


# TEST
sol = solve_tsp(incid, TIME=120)

print("Solution:")
print(sol["route"] + 1)    

print("\nNumber of history points:")
print(len(sol["history"]))

print("\nMinimum Cost:")
print(min(sol["history"]))

plt.plot(sol["history"], color="red")
plt.xlabel("Iteration")
plt.ylabel("Cost")
plt.show()